# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# When unset, the gtag snippet is not injected.
PUBLIC_GA_ID=

# --- One-time migration vars (delete after running `npm run migrate:notion`) ---
# Required only by scripts/migrate-notion-to-mdoc.mjs to pull existing content
# out of Notion. Once content is committed and the script + Notion devDeps are
# removed, these can be deleted.
NOTION_TOKEN=
NOTION_DB_POSTS=
NOTION_DB_PROJECTS=
NOTION_DB_PUBS=
