# Notion integration token (https://www.notion.so/profile/integrations).
# The integration must be shared with each of the three databases below.
NOTION_TOKEN=

# Notion database IDs (the 32-char hex from the database URL).
NOTION_DB_POSTS=
NOTION_DB_PROJECTS=
NOTION_DB_PUBS=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# When unset, the gtag snippet is not injected.
PUBLIC_GA_ID=
