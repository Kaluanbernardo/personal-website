---
import { ui, type Lang } from '../i18n/ui';
import { link, stripBase } from '../lib/links';

interface Props {
  lang: Lang;
  pathname: string;
}
const { lang, pathname } = Astro.props;

const normalized = stripBase(pathname);
const ptHref = link(ui.en.altLang.href(normalized));
const enHref = link(ui.pt.altLang.href(normalized));
---

<span class="lang-toggle">
  <a class={`ed-tag lang ${lang === 'pt' ? 'on' : 'off'}`} href={lang === 'pt' ? '#' : ptHref} aria-current={lang === 'pt' ? 'true' : undefined}>PT</a>
  <a class={`ed-tag lang ${lang === 'en' ? 'on' : 'off'}`} href={lang === 'en' ? '#' : enHref} aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
</span>

<style>
  .lang-toggle { display: inline-flex; gap: 4px; }
  .lang.on { background: var(--accent); color: #000; border-color: #000; }
  .lang.off { opacity: 0.5; }
  .lang.off:hover { background: var(--ylw); color: #000; opacity: 1; }
</style>
