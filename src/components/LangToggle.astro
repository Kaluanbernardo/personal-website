---
import { ui, type Lang } from '../i18n/ui';
import { link, stripBase } from '../lib/links';

interface Props {
  lang: Lang;
  pathname: string;
}
const { lang, pathname } = Astro.props;

// Strip the deploy base from the pathname so the i18n helpers operate on
// site-relative routes (/sobre, /en/sobre), then re-apply via link().
const normalized = stripBase(pathname);
const ptHref = link(ui.en.altLang.href(normalized));
const enHref = link(ui.pt.altLang.href(normalized));
---

<a class={`hf-chip ${lang === 'pt' ? 'active' : ''}`} href={lang === 'pt' ? '#' : ptHref}>PT</a>
<a class={`hf-chip ${lang === 'en' ? 'active' : ''}`} href={lang === 'en' ? '#' : enHref}>EN</a>
