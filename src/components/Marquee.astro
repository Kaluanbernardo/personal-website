---
interface Props {
  items: string[];
  color?: string;
  fast?: boolean;
  rev?: boolean;
}
const { items, color, fast = false, rev = false } = Astro.props;
const klass = ['marquee'];
if (fast) klass.push('fast');
if (rev) klass.push('rev');
const style = color ? `background:${color}` : undefined;
const text = items.join('   ✦   ');
---

<div class={klass.join(' ')} style={style} role="presentation" aria-hidden="true">
  <div class="track">
    <span>{text}&nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp;{text}&nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp;</span>
    <span>{text}&nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp;{text}&nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp;</span>
  </div>
</div>
