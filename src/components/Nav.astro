---
import { ui, type Lang } from '../i18n/ui';
import { link } from '../lib/links';
import Monogram from './Monogram.astro';
import LangToggle from './LangToggle.astro';

interface Props {
  lang: Lang;
  active?: 'home' | 'sobre' | 'cv' | 'academico' | 'blog' | 'projetos' | 'contato';
  variant?: 'full' | 'back';
  backLabel?: string;
  backHref?: string;
  pathname: string;
}
const {
  lang,
  active = 'home',
  variant = 'full',
  backLabel,
  backHref,
  pathname,
} = Astro.props;
const t = ui[lang];
const prefix = lang === 'en' ? '/en' : '';
const linkFor = (key: keyof typeof t.nav) => {
  if (key === 'home') return link(`${prefix}/`);
  if (key === 'menu') return '#';
  const slugs: Record<string, string> = {
    sobre: 'sobre',
    cv: 'cv',
    academico: 'academico',
    blog: 'blog',
    projetos: 'projetos',
    contato: 'contato',
  };
  return link(`${prefix}/${slugs[key]}`);
};
const items: { k: string; key: keyof typeof t.nav; active: boolean }[] = [
  { k: '00', key: 'home', active: active === 'home' },
  { k: '01', key: 'sobre', active: active === 'sobre' },
  { k: '02', key: 'cv', active: active === 'cv' },
  { k: '03', key: 'academico', active: active === 'academico' },
  { k: '04', key: 'blog', active: active === 'blog' },
  { k: '05', key: 'projetos', active: active === 'projetos' },
  { k: '06', key: 'contato', active: active === 'contato' },
];
const username = (t.brand || '').replace(/\s+/g, '_');
---

<header class="site-header">
  {variant === 'full' ? (
    <div class="brand">
      <a href={linkFor('home')} class="brand-link" aria-label={t.brand}>
        <Monogram />
      </a>
      <span class="brand-label">
        {username} <span class="slash">/</span> personal_dot_com
      </span>
    </div>
  ) : (
    <a class="brand brand-back" href={backHref ?? link(`${prefix}/blog`)}>{backLabel ?? t.post.backToList}</a>
  )}

  <button class="menu-toggle" type="button" aria-label="Toggle navigation">{t.nav.menu}</button>

  <nav class="site-nav" aria-label="primary">
    {items.map((it) => (
      <a class={it.active ? 'active' : ''} href={linkFor(it.key)} aria-current={it.active ? 'page' : undefined}>
        <span class="num">{it.k}</span>{t.nav[it.key]}
      </a>
    ))}
  </nav>

  <span class="nav-aux">
    <LangToggle lang={lang} pathname={pathname} />
  </span>
</header>

<style>
  .brand-link {
    display: inline-flex;
    text-decoration: none;
  }
  .brand-link:hover { background: transparent; }
  .brand-back {
    background: transparent;
  }
  .brand-back:hover { background: var(--ylw); color: #000; }

  @media (max-width: 720px) {
    .brand-label { display: none; }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('.site-header');
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  if (header && toggle) {
    toggle.addEventListener('click', () => header.classList.toggle('is-open'));
  }
</script>
