---
import { tagDisplay, type Lang } from '../i18n/ui';

interface Props {
  date: string;
  readingTime: number;
  title: string;
  tag: string;
  href: string;
  lang: Lang;
  variant?: 'card' | 'row';
}
const { date, readingTime, title, tag, href, lang, variant = 'card' } = Astro.props;
const tagLabel = tagDisplay[lang][tag] ?? tag;
const minLabel = lang === 'pt' ? 'min' : 'min';
---

{variant === 'card' ? (
  <a class="post-card" href={href}>
    <div class="post-card-meta">
      <span class="hf-mono date">{date} · {readingTime} {minLabel}</span>
      <span class="hf-mono tag">{tagLabel}</span>
    </div>
    <h4 class="hf-display title">{title}</h4>
  </a>
) : (
  <a class="post-row" href={href}>
    <span class="hf-mono row-date">{date}</span>
    <h3 class="hf-display row-title">{title}</h3>
    <span class="hf-mono row-tag">#{tagLabel}</span>
    <span class="hf-mono row-mins">{readingTime} {minLabel}</span>
  </a>
)}

<style>
  .post-card {
    display: block;
    border-top: 1px solid var(--rule-soft);
    padding-top: 18px;
    transition: border-color 0.18s ease, padding-left 0.25s ease;
  }
  .post-card:hover {
    border-color: var(--accent);
    padding-left: 6px;
  }
  .post-card-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
    gap: 12px;
  }
  .post-card-meta .date {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    text-transform: uppercase;
  }
  .post-card-meta .tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
  }
  .post-card .title {
    font-size: 19px;
    margin: 0;
    font-weight: 600;
    line-height: 1.3;
    transition: color 0.18s ease;
  }
  .post-card:hover .title {
    color: var(--accent);
  }

  .post-row {
    display: grid;
    grid-template-columns: 80px 1fr 100px 60px;
    gap: 18px;
    padding: 16px 0;
    border-bottom: 1px solid var(--rule-soft);
    align-items: baseline;
    transition: padding-left 0.25s ease, border-color 0.18s ease;
  }
  .post-row:hover {
    border-color: var(--accent);
    padding-left: 8px;
  }
  .post-row:hover .row-title {
    color: var(--accent);
  }
  .row-date {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--fg-3);
    text-transform: uppercase;
  }
  .row-title {
    font-size: 20px;
    margin: 0;
    font-weight: 600;
    transition: color 0.18s ease;
  }
  .row-tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
    text-align: right;
  }
  .row-mins {
    font-size: 12px;
    color: var(--fg-3);
    text-align: right;
  }
  @media (max-width: 720px) {
    .post-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }
    .row-tag,
    .row-mins {
      text-align: left;
    }
  }
</style>
