---
import { tagDisplay, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  kind: string;
  place: string;
  href?: string;
  lang: Lang;
}
const { title, kind, place, href, lang } = Astro.props;
const kindLabel = tagDisplay[lang][kind] ?? kind;
---

<article class="project-card">
  <a href={href ?? '#'} target={href ? '_blank' : undefined} rel={href ? 'noreferrer noopener' : undefined}>
    <div class="img-frame thumb">
      <div class="ph">thumb · 4×3</div>
    </div>
    <div class="kind hf-mono">{kindLabel}</div>
    <h3 class="hf-display title">{title}</h3>
    <div class="place hf-mono">{place} <span class="arrow">→</span></div>
  </a>
</article>

<style>
  .project-card a {
    display: block;
    cursor: pointer;
  }
  .thumb {
    aspect-ratio: 4/3;
    margin-bottom: 16px;
    transition: transform 0.3s ease;
  }
  .project-card a:hover .thumb {
    transform: translateY(-3px);
  }
  .kind {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .title {
    font-size: 20px;
    margin: 0 0 8px;
    font-weight: 600;
    line-height: 1.3;
    transition: color 0.18s ease;
  }
  .project-card a:hover .title {
    color: var(--accent);
  }
  .place {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    text-transform: uppercase;
  }
  .arrow {
    transition: margin-left 0.18s ease;
    display: inline-block;
  }
  .project-card a:hover .arrow {
    margin-left: 4px;
    color: var(--accent);
  }
</style>
