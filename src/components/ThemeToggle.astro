---
// Renders the theme toggle button. The pre-paint theme bootstrap lives in Base.astro.
---

<button class="ad-tag theme-toggle" type="button" aria-label="Toggle theme" title="Toggle theme">◐ TEMA</button>

<style>
  .theme-toggle {
    background: var(--ylw);
    color: #000;
    border-color: #000;
    cursor: pointer;
  }
  .theme-toggle:hover { background: var(--acid); }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.theme-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {
        /* ignore */
      }
    });
  }
</script>
