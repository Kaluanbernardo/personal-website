---
import { getCollection } from 'astro:content';
import { ui, type Lang, tagDisplay } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const allPubs = await getCollection('pubs', ({ data }) => data.lang === lang);
const publications = allPubs
  .map((p) => p.data)
  .sort((a, b) => b.year - a.year);

const eyebrow = '03 / LATTES.CNPQ.BR';
const linesHeading = lang === 'en' ? '>> RESEARCH LINES' : '>> LINHAS DE PESQUISA';
const formationHeading = lang === 'en' ? '>> EDUCATION' : '>> FORMAÇÃO';
const pubsHeading = lang === 'en' ? '>> SELECTED PUBLICATIONS' : '>> PUBLICAÇÕES SELECIONADAS';
---

<header class="head">
  <div class="kicker">{eyebrow}</div>
  <h1 class="ad-bungee headline">
    <span class="t-acid">{t.academico.title.line1.toUpperCase()}</span>
    <span class="ad-bungee-s">{t.academico.title.emph.toUpperCase()}</span>
    <span class="ad-blink">_</span>
  </h1>
  <div class="scholar-row">
    {t.academico.scholarIds.map((s) => (
      <a class="ad-btn scholar-btn" href={s.href} target="_blank" rel="noreferrer noopener">
        {s.label} ↗
      </a>
    ))}
  </div>
</header>

<section class="lines">
  <div class="section-kicker acid">{linesHeading}</div>
  <hr class="ad-rule" style="border-top-color: var(--acid)" />
  <div class="line-tags">
    {t.academico.lines.map((l, i) => {
      const bgs = ['var(--acid)', 'var(--hot)', 'var(--cyan)', 'var(--ylw)'];
      const bg = bgs[i % bgs.length];
      return (
        <span class="ad-tag line-tag" style={`background:${bg};color:#000;border-color:#000`}>
          {l}
        </span>
      );
    })}
  </div>
</section>

<section class="main-grid">
  <aside class="formation">
    <div class="section-kicker cyan">{formationHeading}</div>
    <hr class="ad-rule" style="border-top-color: var(--cyan)" />
    <div class="formation-list">
      {t.academico.formation.map((e) => (
        <article class="formation-row">
          <span class="period">{e.p}</span>
          <h3 class="ad-bungee role">{e.r}</h3>
          <div class="org">{e.o}</div>
          <p class="desc">{e.d}</p>
        </article>
      ))}
    </div>
  </aside>

  <div class="pubs">
    <div class="section-kicker vio">{pubsHeading}</div>
    <hr class="ad-rule" style="border-top-color: var(--vio)" />
    {publications.length === 0 ? (
      <div class="empty">
        <span class="ad-blink">[ ]</span> {lang === 'en' ? 'no publications listed yet.' : 'sem publicações listadas ainda.'}
      </div>
    ) : (
      <div class="pub-list">
        {publications.map((p) => (
          <a class="pub-row" href={p.url ?? '#'} target={p.url ? '_blank' : undefined} rel={p.url ? 'noreferrer noopener' : undefined}>
            <span class="pub-year">{p.year}</span>
            <div class="pub-body">
              <h3 class="ad-bungee pub-title">{p.title}</h3>
              <div class="pub-venue">{p.venue}</div>
            </div>
            <span class="pub-tag">#{tagDisplay[lang][p.kind] ?? p.kind}</span>
            <span class="pub-arrow">↗</span>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .head { padding-top: 6px; margin-bottom: 36px; }
  .kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--acid);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .headline {
    font-size: clamp(48px, 8vw, 88px);
    margin: 0 0 18px;
    line-height: 0.85;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }
  .headline .t-acid {
    background: var(--acid);
    color: #000;
    padding: 0 8px;
  }
  .scholar-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .scholar-btn {
    font-size: 11px;
    padding: 6px 10px;
  }

  .section-kicker {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--acid);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .section-kicker.cyan { color: var(--cyan); }
  .section-kicker.vio { color: var(--vio); }

  .lines { margin-bottom: 36px; }
  .line-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }
  .line-tag { font-size: 11px; padding: 4px 8px; }

  .main-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 36px;
    align-items: flex-start;
  }

  .formation-list { margin-top: 14px; }
  .formation-row {
    padding: 14px 0;
    border-bottom: 1.5px dashed var(--fg);
  }
  .period {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--cyan);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .role {
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin: 0 0 4px;
  }
  .org {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--fg-2);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .desc {
    font-family: var(--serif);
    font-size: 14px;
    margin: 0;
    line-height: 1.5;
  }

  .pub-list { margin-top: 14px; }
  .pub-row {
    display: grid;
    grid-template-columns: 64px 1fr 120px 24px;
    gap: 18px;
    padding: 14px 0;
    border-bottom: 1.5px solid var(--fg);
    align-items: baseline;
  }
  .pub-row:hover { background: transparent; padding-left: 8px; }
  .pub-row:hover .pub-title { color: var(--vio); }
  .pub-year {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--vio);
  }
  .pub-title {
    font-size: 19px;
    margin: 0 0 4px;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .pub-venue {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--fg-2);
  }
  .pub-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--vio);
    text-transform: uppercase;
    text-align: right;
  }
  .pub-arrow {
    font-size: 16px;
    color: var(--vio);
    text-align: right;
  }
  .empty {
    padding: 18px 0;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .main-grid { grid-template-columns: 1fr; gap: 24px; }
    .pub-row { grid-template-columns: 60px 1fr 24px; }
    .pub-tag { grid-column: 2; text-align: left; }
    .pub-arrow { grid-row: 1; grid-column: 3; text-align: right; }
  }
</style>
