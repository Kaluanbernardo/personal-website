---
import { getCollection } from 'astro:content';
import { ui, type Lang, tagDisplay } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const allPubs = await getCollection('pubs', ({ data }) => data.lang === lang);
const publications = allPubs
  .map((p) => p.data)
  .sort((a, b) => b.year - a.year);
---

<header class="head">
  <div class="eyebrow hf-mono">{t.academico.eyebrow}</div>
  <h1 class="hf-display headline">
    {t.academico.title.line1}{t.academico.title.emph}
  </h1>
  <div class="scholar-row">
    {t.academico.scholarIds.map((s) => (
      <a class="scholar-link" href={s.href} target="_blank" rel="noreferrer noopener">
        {s.label} <span aria-hidden="true">↗</span>
      </a>
    ))}
  </div>
</header>

<section class="lines">
  <div class="kicker hf-mono">{t.academico.linesHeading}</div>
  <div class="line-tags">
    {t.academico.lines.map((l) => <span class="hf-tag">{l}</span>)}
  </div>
</section>

<section class="block">
  <div class="kicker hf-mono">{t.academico.formationHeading}</div>
  <div class="formation-list">
    {t.academico.formation.map((e) => (
      <div class="formation-row">
        <span class="period hf-mono">{e.p}</span>
        <div class="formation-body">
          <div class="hf-display role">{e.r}</div>
          <div class="org">{e.o}</div>
          <p class="desc">{e.d}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<section class="block">
  <div class="kicker hf-mono">{t.academico.publicationsHeading}</div>
  <div class="pub-list">
    {publications.map((p) => (
      <a class="pub-row" href={p.url ?? '#'} target={p.url ? '_blank' : undefined} rel={p.url ? 'noreferrer noopener' : undefined}>
        <span class="pub-year hf-mono">{p.year}</span>
        <div class="pub-body">
          <div class="hf-display pub-title">{p.title}</div>
          <div class="pub-venue">{p.venue}</div>
        </div>
        <span class="pub-tag hf-mono">#{tagDisplay[lang][p.kind] ?? p.kind}</span>
        <span class="pub-arrow hf-mono">↗</span>
      </a>
    ))}
  </div>
</section>

<style>
  .head {
    margin-bottom: 56px;
  }
  .eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .headline {
    font-size: 56px;
    margin: 0 0 24px;
    line-height: 1.05;
  }
  .scholar-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .lines {
    margin-bottom: 56px;
  }
  .line-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .block {
    margin-bottom: 56px;
  }
  .kicker {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .formation-list {
    display: flex;
    flex-direction: column;
  }
  .formation-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 32px;
    padding: 28px 0;
    border-bottom: 1px solid var(--rule-soft);
    align-items: start;
  }
  .formation-row:first-child {
    border-top: 1px solid var(--rule-soft);
  }
  .period {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--fg-3);
    text-transform: uppercase;
    padding-top: 4px;
  }
  .formation-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .role {
    font-size: 22px;
    font-weight: 600;
    line-height: 1.2;
  }
  .org {
    font-size: 14px;
    font-family: var(--mono);
    color: var(--fg-2);
    letter-spacing: 0.04em;
    margin-bottom: 4px;
  }
  .desc {
    font-size: 16px;
    color: var(--fg-2);
    margin: 0;
    line-height: 1.6;
    max-width: 720px;
  }

  .pub-list {
    display: flex;
    flex-direction: column;
  }
  .pub-row {
    display: grid;
    grid-template-columns: 80px 1fr 140px 32px;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--rule-soft);
    align-items: start;
    transition: padding-left 0.25s ease, border-color 0.18s ease;
  }
  .pub-row:first-child {
    border-top: 1px solid var(--rule-soft);
  }
  .pub-row:hover {
    border-color: var(--accent);
    padding-left: 12px;
  }
  .pub-row:hover .pub-title {
    color: var(--accent);
  }
  .pub-row:hover .pub-arrow {
    color: var(--accent);
  }
  .pub-year {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    padding-top: 4px;
  }
  .pub-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .pub-title {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    transition: color 0.18s ease;
  }
  .pub-venue {
    font-size: 14px;
    color: var(--fg-2);
    line-height: 1.4;
  }
  .pub-tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
    padding-top: 4px;
    text-align: right;
  }
  .pub-arrow {
    font-size: 14px;
    color: var(--fg-3);
    text-align: right;
    padding-top: 4px;
    transition: color 0.18s ease;
  }

  @media (max-width: 720px) {
    .headline {
      font-size: 40px;
    }
    .formation-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .pub-row {
      grid-template-columns: 60px 1fr 24px;
      gap: 14px;
    }
    .pub-tag {
      grid-column: 2;
      text-align: left;
      padding-top: 0;
    }
    .pub-arrow {
      grid-row: 1;
      grid-column: 3;
    }
  }
</style>
