---
import { getCollection } from 'astro:content';
import { ui, type Lang, formatDate, tagDisplay } from '../../i18n/ui';
import { link } from '../../lib/links';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const posts = (await getCollection('posts', ({ data }) => !data.draft && data.lang === lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const prefix = lang === 'en' ? '/en' : '';
const minLabel = lang === 'pt' ? 'min' : 'min';
const postHref = (slug: string) => link(`${prefix}/blog/${slug}`);

// Map filter labels to canonical tag values
const tagOrder: string[] = ['produto', 'jornalismo', 'academia', 'leitura', 'notas'];
const tagByFilter: Record<string, string | null> = {};
t.blog.filters.forEach((label, i) => {
  tagByFilter[label] = i === 0 ? null : tagOrder[i - 1] ?? null;
});
---

<header class="head">
  <div class="eyebrow hf-mono">{t.blog.eyebrow}</div>
  <h1 class="hf-display headline">
    {t.blog.title.line1}{t.blog.title.emph}
  </h1>
</header>

<div class="filters">
  {t.blog.filters.map((label, i) => (
    <button type="button" class={`hf-tag filter-btn ${i === 0 ? 'accent active' : ''}`} data-tag={tagByFilter[label] ?? ''}>{label}</button>
  ))}
</div>

<div class="post-list">
  {posts.map((p) => (
    <a class="post-row" href={postHref(p.slug)} data-tag={p.data.tag}>
      <span class="rdate hf-mono">{formatDate(p.data.pubDate, lang)}</span>
      <div class="rbody">
        <h3 class="hf-display rtitle">{p.data.title}</h3>
        <p class="rdesc">{p.data.description}</p>
      </div>
      <span class="rtag hf-mono">#{tagDisplay[lang][p.data.tag] ?? p.data.tag}</span>
      <span class="rmins hf-mono">{p.data.readingTime} {minLabel}</span>
    </a>
  ))}
</div>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const rows = document.querySelectorAll<HTMLElement>('.post-row[data-tag]');
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('accent', 'active'));
      btn.classList.add('accent', 'active');
      const target = btn.dataset.tag ?? '';
      rows.forEach((row) => {
        const match = !target || row.dataset.tag === target;
        row.style.display = match ? '' : 'none';
      });
    });
  });
</script>

<style>
  .head {
    margin-bottom: 32px;
  }
  .eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .headline {
    font-size: 56px;
    margin: 0 0 12px;
    line-height: 1.05;
  }
  .meta {
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin: 0;
  }

  .filters {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }
  .post-row {
    display: grid;
    grid-template-columns: 100px 1fr 140px 80px;
    gap: 28px;
    padding: 28px 0;
    border-bottom: 1px solid var(--rule-soft);
    align-items: start;
    transition: padding-left 0.25s ease, border-color 0.18s ease;
  }
  .post-row:first-child {
    border-top: 1px solid var(--rule-soft);
  }
  .post-row:hover {
    border-color: var(--accent);
    padding-left: 12px;
  }
  .post-row:hover .rtitle {
    color: var(--accent);
  }
  .rdate {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--fg-3);
    text-transform: uppercase;
    padding-top: 6px;
  }
  .rbody {
    min-width: 0;
  }
  .rtitle {
    font-size: 22px;
    margin: 0 0 6px;
    font-weight: 600;
    line-height: 1.25;
    transition: color 0.18s ease;
  }
  .rdesc {
    font-size: 15px;
    color: var(--fg-2);
    margin: 0;
    line-height: 1.55;
    max-width: 620px;
  }
  .rtag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
    text-align: right;
    padding-top: 6px;
  }
  .rmins {
    font-size: 12px;
    color: var(--fg-3);
    text-align: right;
    padding-top: 6px;
  }
  @media (max-width: 720px) {
    .headline {
      font-size: 40px;
    }
    .post-row {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 20px 0;
    }
    .post-row:hover {
      padding-left: 0;
    }
    .rtag,
    .rmins {
      text-align: left;
      padding-top: 0;
    }
    .rdate {
      padding-top: 0;
    }
  }
</style>
