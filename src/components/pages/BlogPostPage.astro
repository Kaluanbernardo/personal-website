---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { ui, formatLongDate, tagDisplay, type Lang } from '../../i18n/ui';
import { link } from '../../lib/links';

interface Props {
  lang: Lang;
  post: CollectionEntry<'posts'>;
}
const { lang, post } = Astro.props;
const t = ui[lang];
const prefix = lang === 'en' ? '/en' : '';
const postHref = (slug: string) => link(`${prefix}/blog/${slug}`);

const all = (await getCollection('posts', ({ data }) => !data.draft && data.lang === lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const idx = all.findIndex((p) => p.id === post.id);
const prev = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : undefined;
const next = idx > 0 ? all[idx - 1] : undefined;

const { Content } = await render(post);
const tagLabel = tagDisplay[lang][post.data.tag] ?? post.data.tag;
---

<article class="post">
  <div class="kicker">#{tagLabel}</div>
  <h1 class="ad-bungee title">{post.data.title}</h1>
  <div class="meta">
    {t.post.metaJoin(formatLongDate(post.data.pubDate, lang), post.data.readingTime)}
  </div>

  <hr class="ad-rule-rainbow" />

  <p class="lead serif">{post.data.description}</p>

  <div class="prose">
    <Content />
  </div>

  <hr class="ad-rule-dashed sep" />
  <nav class="post-nav">
    {prev ? <a class="nav-link" href={postHref(prev.id)}>{t.post.prev}</a> : <span></span>}
    <a class="nav-link accent" href="https://example.substack.com" target="_blank" rel="noreferrer noopener">{t.post.subscribe}</a>
    {next ? <a class="nav-link" href={postHref(next.id)}>{t.post.next}</a> : <span></span>}
  </nav>
</article>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding-top: 6px;
  }
  .kicker {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--vio);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .title {
    font-size: clamp(36px, 6vw, 60px);
    margin: 0 0 14px;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -0.03em;
  }
  .meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .lead {
    font-family: var(--serif);
    font-size: 22px;
    color: var(--fg);
    line-height: 1.5;
    margin: 24px 0 32px;
  }
  .serif { font-family: var(--serif); }
  .prose {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.7;
    color: var(--fg);
  }
  .prose :global(h2) {
    font-family: var(--bungee);
    font-weight: 400;
    font-size: 28px;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin: 48px 0 16px;
    line-height: 1;
  }
  .prose :global(h3) {
    font-family: var(--bungee);
    font-weight: 400;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 36px 0 14px;
  }
  .prose :global(p) { margin: 0 0 20px; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--vio);
    padding: 4px 0 4px 24px;
    margin: 36px 0;
    font-family: var(--bungee);
    font-size: 22px;
    color: var(--fg);
    line-height: 1.2;
    text-transform: uppercase;
  }
  .prose :global(blockquote p) { margin: 0; }
  .prose :global(a) {
    color: var(--vio);
    border-bottom: 1.5px solid var(--vio);
    transition: background 0.05s linear, color 0.05s linear;
  }
  .prose :global(a:hover) { background: var(--ylw); color: #000; border-bottom-color: #000; }
  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--bg-2);
    padding: 2px 6px;
  }
  .prose :global(pre) {
    background: var(--bg-2);
    padding: 16px 20px;
    overflow-x: auto;
    font-family: var(--mono);
    font-size: 13px;
    border: 2px solid var(--fg);
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 22px;
    margin: 0 0 20px;
  }
  .prose :global(li) { margin-bottom: 8px; }
  .sep { margin: 56px 0 22px; }
  .post-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .nav-link {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--fg-2);
    text-transform: uppercase;
    border: 2px solid var(--fg);
    padding: 6px 10px;
  }
  .nav-link:hover { background: var(--ylw); color: #000; border-color: #000; }
  .nav-link.accent {
    background: var(--vio);
    color: #fff;
    border-color: var(--vio);
  }
  .nav-link.accent:hover { background: var(--ylw); color: #000; border-color: #000; }

  @media (max-width: 720px) {
    .lead { font-size: 18px; }
    .prose { font-size: 16px; }
    .post-nav { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
