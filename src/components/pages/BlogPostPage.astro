---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { ui, formatLongDate, tagDisplay, type Lang } from '../../i18n/ui';
import { link } from '../../lib/links';

interface Props {
  lang: Lang;
  post: CollectionEntry<'posts'>;
}
const { lang, post } = Astro.props;
const t = ui[lang];
const prefix = lang === 'en' ? '/en' : '';
const postHref = (slug: string) => link(`${prefix}/blog/${slug}`);

const all = (await getCollection('posts', ({ data }) => !data.draft && data.lang === lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const idx = all.findIndex((p) => p.id === post.id);
const prev = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : undefined;
const next = idx > 0 ? all[idx - 1] : undefined;

const { Content } = await render(post);
const tagLabel = tagDisplay[lang][post.data.tag] ?? post.data.tag;
---

<article class="post">
  <div class="kicker hf-mono">#{tagLabel}</div>
  <h1 class="hf-display title">{post.data.title}</h1>
  <div class="meta hf-mono">
    {t.post.metaJoin(formatLongDate(post.data.pubDate, lang), post.data.readingTime)}
  </div>

  <p class="lead">{post.data.description}</p>

  <div class="prose">
    <Content />
  </div>

  <hr class="hf-rule-soft sep" />
  <nav class="post-nav">
    {prev ? <a class="hf-mono nav-link" href={postHref(prev.id)}>{t.post.prev}</a> : <span></span>}
    <a class="hf-mono nav-link accent" href="https://example.substack.com" target="_blank" rel="noreferrer noopener">{t.post.subscribe}</a>
    {next ? <a class="hf-mono nav-link" href={postHref(next.id)}>{t.post.next}</a> : <span></span>}
  </nav>
</article>

<style>
  .post {
    max-width: 680px;
    margin: 0 auto;
  }
  .kicker {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 16px;
    text-align: center;
  }
  .title {
    font-size: 48px;
    margin: 0 0 20px;
    line-height: 1.1;
    text-align: center;
  }
  .meta {
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 56px;
  }
  .lead {
    font-size: 22px;
    color: var(--fg);
    font-weight: 500;
    line-height: 1.5;
    margin: 0 0 32px;
  }
  .prose {
    font-size: 18px;
    line-height: 1.7;
    color: var(--fg-2);
  }
  .prose :global(h2) {
    font-family: var(--display);
    font-weight: 600;
    font-size: 28px;
    letter-spacing: -0.015em;
    color: var(--fg);
    margin: 48px 0 16px;
    line-height: 1.2;
  }
  .prose :global(h3) {
    font-family: var(--display);
    font-weight: 600;
    font-size: 22px;
    color: var(--fg);
    margin: 36px 0 14px;
  }
  .prose :global(p) {
    margin: 0 0 20px;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 4px 0 4px 24px;
    margin: 36px 0;
    font-family: var(--display);
    font-size: 22px;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.45;
  }
  .prose :global(blockquote p) {
    margin: 0;
  }
  .prose :global(a) {
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
    transition: opacity 0.18s ease;
  }
  .prose :global(a:hover) {
    opacity: 0.7;
  }
  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.9em;
    background: var(--bg-2);
    padding: 2px 6px;
    border-radius: 3px;
  }
  .prose :global(pre) {
    background: var(--bg-2);
    padding: 16px 20px;
    overflow-x: auto;
    font-family: var(--mono);
    font-size: 13px;
    border-radius: 3px;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 22px;
    margin: 0 0 20px;
  }
  .prose :global(li) {
    margin-bottom: 8px;
  }
  .sep {
    margin: 64px 0 28px;
  }
  .post-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .nav-link {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--fg-2);
    text-transform: uppercase;
    transition: color 0.18s ease;
  }
  .nav-link.accent {
    color: var(--accent);
  }
  .nav-link:hover {
    color: var(--accent);
  }
  @media (max-width: 720px) {
    .title {
      font-size: 32px;
    }
    .lead {
      font-size: 18px;
    }
    .prose {
      font-size: 16px;
    }
    .post-nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
