---
import { ui, type Lang } from '../../i18n/ui';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const pdfHref = lang === 'en' ? '/cv-en.pdf' : '/cv-pt.pdf';
---

<div class="head row-flex">
  <div>
    <div class="eyebrow hf-mono">{t.cv.eyebrow}</div>
    <h1 class="hf-display headline display-lg">
      {t.cv.title.line1}<span class="ital">{t.cv.title.emph}</span>
    </h1>
  </div>
  <a class="hf-btn solid" href={pdfHref} download>{t.cv.download}</a>
</div>
<p class="updated hf-mono">{t.cv.updated}</p>

<div class="kicker hf-mono">{t.cv.experienceHeading}</div>
{t.cv.experience.map((e) => (
  <div class="exp-row">
    <span class="exp-period hf-mono">{e.p}</span>
    <div>
      <div class="hf-display exp-role">{e.r}</div>
      <div class="hf-serif exp-org">{e.o}</div>
      <p class="hf-serif exp-desc">{e.d}</p>
    </div>
    <span class="exp-cta hf-mono">{e.cta}</span>
  </div>
))}

<div class="kicker hf-mono skills-kicker">{t.cv.skillsHeading}</div>
<div class="skills">
  {t.cv.skills.map((s) => <span class="hf-tag">{s}</span>)}
</div>

<style>
  .head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 32px;
    gap: 16px;
  }
  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .headline {
    font-size: 72px;
    margin: 0;
    line-height: 0.95;
  }
  .ital {
    font-style: italic;
  }
  .updated {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin: 0 0 32px;
  }
  .kicker {
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .exp-row {
    display: grid;
    grid-template-columns: 180px 1fr 100px;
    gap: 24px;
    padding: 18px 0;
    border-bottom: 1px solid var(--rule-soft);
  }
  .exp-period {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--fg-3);
    text-transform: uppercase;
  }
  .exp-role {
    font-size: 24px;
    font-weight: 500;
  }
  .exp-org {
    font-size: 14px;
    font-style: italic;
    color: var(--fg-2);
    margin-bottom: 8px;
  }
  .exp-desc {
    font-size: 15px;
    color: var(--fg-2);
    margin: 0;
    line-height: 1.55;
  }
  .exp-cta {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--accent);
    text-transform: uppercase;
    text-align: right;
  }
  .skills-kicker {
    margin-top: 32px;
  }
  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  @media (max-width: 720px) {
    .exp-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .exp-cta {
      text-align: left;
    }
    .headline {
      font-size: 48px;
    }
  }
</style>
