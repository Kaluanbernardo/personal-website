---
import { ui, type Lang } from '../../i18n/ui';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const pdfHref = lang === 'en' ? '/cv-en.pdf' : '/cv-pt.pdf';
---

<div class="head row-flex">
  <div>
    <div class="eyebrow hf-mono">{t.cv.eyebrow}</div>
    <h1 class="hf-display headline">
      {t.cv.title.line1}{t.cv.title.emph}
    </h1>
  </div>
  <a class="hf-btn solid" href={pdfHref} download>{t.cv.download}</a>
</div>
<p class="updated hf-mono">{t.cv.updated}</p>

<div class="kicker hf-mono">{t.cv.experienceHeading}</div>
<div class="exp-list">
  {t.cv.experience.map((e) => (
    <div class="exp-row">
      <span class="exp-period hf-mono">{e.p}</span>
      <div class="exp-body">
        <div class="hf-display exp-role">{e.r}</div>
        <div class="exp-org">{e.o}</div>
        <p class="exp-desc">{e.d}</p>
      </div>
      <a class="exp-cta hf-mono" href="#">{e.cta}</a>
    </div>
  ))}
</div>

<div class="kicker hf-mono skills-kicker">{t.cv.skillsHeading}</div>
<div class="skills">
  {t.cv.skills.map((s) => <span class="hf-tag">{s}</span>)}
</div>

<style>
  .head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 16px;
    gap: 24px;
  }
  .eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .headline {
    font-size: 56px;
    margin: 0;
    line-height: 1.05;
  }
  .updated {
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin: 0 0 48px;
  }
  .kicker {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .exp-list {
    margin-bottom: 12px;
  }
  .exp-row {
    display: grid;
    grid-template-columns: 180px 1fr 100px;
    gap: 32px;
    padding: 32px 0;
    border-bottom: 1px solid var(--rule-soft);
    align-items: start;
  }
  .exp-row:first-child {
    border-top: 1px solid var(--rule-soft);
  }
  .exp-period {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--fg-3);
    text-transform: uppercase;
    padding-top: 4px;
  }
  .exp-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .exp-role {
    font-size: 22px;
    font-weight: 600;
    line-height: 1.2;
  }
  .exp-org {
    font-size: 14px;
    color: var(--fg-2);
    font-family: var(--mono);
    letter-spacing: 0.04em;
  }
  .exp-desc {
    font-size: 16px;
    color: var(--fg-2);
    margin: 4px 0 0;
    line-height: 1.6;
    max-width: 620px;
  }
  .exp-cta {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--fg-2);
    text-transform: uppercase;
    text-align: right;
    padding-top: 6px;
    transition: color 0.18s ease;
  }
  .exp-cta:hover {
    color: var(--accent);
  }
  .skills-kicker {
    margin-top: 56px;
  }
  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  @media (max-width: 720px) {
    .head {
      align-items: flex-start;
    }
    .exp-row {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 24px 0;
    }
    .exp-cta {
      text-align: left;
    }
    .headline {
      font-size: 40px;
    }
  }
</style>
