---
import { getCollection } from 'astro:content';
import { ui, type Lang, formatDate } from '../../i18n/ui';
import { link } from '../../lib/links';
import PostCard from '../PostCard.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.lang === lang);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const prefix = lang === 'en' ? '/en' : '';
const postHref = (slug: string) => link(`${prefix}/blog/${slug}`);
const blogHref = link(`${prefix}/blog`);
const projetosHref = link(`${prefix}/projetos`);
const cvPdfHref = link(lang === 'en' ? '/cv-en.pdf' : '/cv-pt.pdf');
---

<section class="hero">
  <div>
    <div class="eyebrow hf-mono">{t.home.eyebrow}</div>
    <h1 class="hf-display headline">
      {t.home.title.line1}<br />
      {t.home.title.line2}
    </h1>
    <p class="intro">{t.home.intro}</p>
    <div class="cta-row">
      <a class="hf-btn solid" href={blogHref}>{t.home.ctaBlog}</a>
      <a class="hf-btn" href={cvPdfHref} download>{t.home.ctaCV}</a>
    </div>
  </div>
  <div>
    <div class="img-frame photo">
      <div class="ph">retrato · 4×5</div>
    </div>
    <div class="photo-credit hf-mono">{t.home.photoCredit}</div>
  </div>
</section>

<hr class="hf-rule" />

<section class="cards grid-3">
  {t.home.cards.map((c) => (
    <a class="card" href={projetosHref}>
      <div class="card-num hf-mono">{c.n}</div>
      <h3 class="hf-display card-title">{c.t}</h3>
      <p class="card-sub">{c.sub}</p>
      <span class="hf-mono card-cta">{c.cta}</span>
    </a>
  ))}
</section>

<section class="from-blog">
  <div class="row-flex from-blog-head">
    <h3 class="hf-display from-blog-title">{t.home.fromBlog}</h3>
    <a class="hf-mono from-blog-all" href={blogHref}>{t.home.allPosts}</a>
  </div>
  <div class="grid-3 posts">
    {recentPosts.map((p) => (
      <PostCard
        date={formatDate(p.data.pubDate, lang).toUpperCase()}
        readingTime={p.data.readingTime}
        title={p.data.title}
        tag={p.data.tag}
        href={postHref(p.slug)}
        lang={lang}
        variant="card"
      />
    ))}
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: start;
    padding: 16px 0 64px;
  }
  .eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 22px;
  }
  .headline {
    font-size: 72px;
    margin: 0 0 22px;
    line-height: 1.0;
  }
  .intro {
    font-size: 18px;
    line-height: 1.6;
    color: var(--fg-2);
    max-width: 480px;
    margin: 0 0 32px;
  }
  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .photo {
    aspect-ratio: 4/5;
    width: 100%;
  }
  .photo-credit {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--fg-3);
    text-align: right;
    margin-top: 8px;
    text-transform: uppercase;
  }
  .cards {
    margin: 36px 0 56px;
  }
  .card {
    display: block;
    padding: 24px 0;
    border-top: 1px solid var(--rule-soft);
    transition: border-color 0.18s ease, padding-left 0.25s ease;
    cursor: pointer;
  }
  .card:hover {
    border-color: var(--accent);
    padding-left: 12px;
  }
  .card-num {
    font-size: 12px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 12px;
  }
  .card-title {
    font-size: 26px;
    margin: 0 0 12px;
    font-weight: 600;
  }
  .card:hover .card-title {
    color: var(--accent);
  }
  .card-sub {
    font-size: 15px;
    color: var(--fg-2);
    margin: 0 0 14px;
    line-height: 1.55;
  }
  .card-cta {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-2);
  }
  .card:hover .card-cta {
    color: var(--accent);
  }
  .from-blog {
    padding-top: 16px;
  }
  .from-blog-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 24px;
  }
  .from-blog-title {
    font-size: 24px;
    margin: 0;
  }
  .from-blog-all {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-2);
  }
  .from-blog-all:hover {
    color: var(--accent);
  }
  @media (max-width: 720px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .headline {
      font-size: 48px;
    }
    .intro {
      font-size: 16px;
    }
  }
</style>
