---
import { getCollection } from 'astro:content';
import { ui, type Lang, formatDate, formatLongDate, tagDisplay } from '../../i18n/ui';
import { link } from '../../lib/links';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.lang === lang);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allProjects = await getCollection('projects', ({ data }) => data.lang === lang);

const prefix = lang === 'en' ? '/en' : '';
const postHref = (slug: string) => link(`${prefix}/blog/${slug}`);
const blogHref = link(`${prefix}/blog`);
const cvPdfHref = link(lang === 'en' ? '/cv-en.pdf' : '/cv-pt.pdf');

const indexEntries = [
  {
    n: '01',
    t: lang === 'en' ? 'ABOUT' : 'SOBRE',
    sub: '> who_is_this.txt',
    meta: lang === 'en' ? '2 min' : '2 min',
    href: link(`${prefix}/sobre`),
    color: 'var(--cyan)',
  },
  {
    n: '02',
    t: lang === 'en' ? 'PROFESSIONAL CV' : 'CV PROFISSIONAL',
    sub: '> work_history.pdf',
    meta: 'PDF',
    href: link(`${prefix}/cv`),
    color: 'var(--ylw)',
  },
  {
    n: '03',
    t: lang === 'en' ? 'ACADEMIC CV' : 'CV ACADÊMICO',
    sub: '> lattes.cnpq.br',
    meta: 'CV',
    href: link(`${prefix}/academico`),
    color: 'var(--acid)',
  },
  {
    n: '04',
    t: lang === 'en' ? 'PROJECTS' : 'PROJETOS',
    sub: '> ./output/*',
    meta: lang === 'en'
      ? `${allProjects.length} ${allProjects.length === 1 ? 'item' : 'items'}`
      : `${allProjects.length} ${allProjects.length === 1 ? 'item' : 'itens'}`,
    href: link(`${prefix}/projetos`),
    color: 'var(--orng)',
  },
  {
    n: '05',
    t: 'BLOG',
    sub: '> cat *.md',
    meta: lang === 'en'
      ? `${allPosts.length} ${allPosts.length === 1 ? 'post' : 'posts'}`
      : `${allPosts.length} posts`,
    href: blogHref,
    color: 'var(--vio)',
  },
  {
    n: '06',
    t: lang === 'en' ? 'CONTACT' : 'CONTATO',
    sub: '> echo $EMAIL',
    meta: '@',
    href: link(`${prefix}/contato`),
    color: 'var(--hot)',
  },
];

const heroTags = lang === 'en'
  ? ['Product', 'Journalism', 'Content', 'Technology', 'Games', 'Culture', 'Strategy', 'AI', 'Education', 'Anything_You_Want_Just_Dream']
  : ['Produto', 'Jornalismo', 'Conteúdo', 'Tecnologia', 'Games', 'Cultura', 'Estratégia', 'IA', 'Educação', 'Tudo_O_Que_Você_Quiser_Basta_Sonhar'];

const now = new Date();
const [dateDay, dateMon, dateYr] = formatLongDate(now, lang).split(' ');
const locationLabel = lang === 'en'
  ? 'SÃO PAULO, BRAZIL, SOUTH AMERICA, EARTH'
  : 'SÃO PAULO, BRASIL, AMÉRICA DO SUL, TERRA';
const indexHeading = lang === 'en' ? 'INDEX / RAW NAVIGATION' : 'ÍNDICE / NAVEGAÇÃO RAW';
const entriesLabel = lang === 'en' ? `0${indexEntries.length}_ENTRIES` : `0${indexEntries.length}_ENTRADAS`;

const fromBlogHeading = lang === 'en' ? 'FROM THE BLOG.' : 'DO BLOG.';
const allPostsLabel = lang === 'en' ? 'ALL POSTS →' : 'TODOS OS POSTS →';

const heroTitle = (t.brand || '').split(' ');
const firstName = heroTitle[0] || 'NOME';
const lastName = heroTitle.slice(1).join(' ') || 'SOBRENOME';
const lastFirstHalf = lastName.slice(0, Math.ceil(lastName.length / 2)) || 'SOBRE';
const lastSecondHalf = lastName.slice(Math.ceil(lastName.length / 2)) || 'NOME';
---

<section class="hero">
  <div class="hero-grid-bg" aria-hidden="true"></div>

  <div class="ai-seal" role="img" aria-label="Selo: Inteligência as a service">
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="aiSealGrad" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="200" y2="200">
          <stop offset="0%" stop-color="#ff2d55" />
          <stop offset="20%" stop-color="#ff6a00" />
          <stop offset="40%" stop-color="#ffe600" />
          <stop offset="55%" stop-color="#c4ff00" />
          <stop offset="75%" stop-color="#00f0ff" />
          <stop offset="100%" stop-color="#b400ff" />
        </linearGradient>
      </defs>
      <polygon
        points="100,4 111.2,14.7 124.9,7.3 132.9,20.5 148,16.9 152.4,31.8 167.9,32.1 168.2,47.6 183.1,52 179.5,67.1 192.7,75.2 185.3,88.8 196,100 185.3,111.2 192.7,124.9 179.5,132.9 183.1,148 168.2,152.4 167.9,167.9 152.4,168.2 148,183.1 132.9,179.5 124.9,192.7 111.2,185.3 100,196 88.8,185.3 75.2,192.7 67.1,179.5 52,183.1 47.6,168.2 32.1,167.9 31.8,152.4 16.9,148 20.5,132.9 7.3,124.9 14.7,111.2 4,100 14.7,88.8 7.3,75.2 20.5,67.1 16.9,52 31.8,47.6 32.1,32.1 47.6,31.8 52,16.9 67.1,20.5 75.2,7.3 88.8,14.7"
        fill="url(#aiSealGrad)"
        stroke="#000"
        stroke-width="3"
        stroke-linejoin="round"
      />
      <g font-family="Bungee, sans-serif" font-weight="700" fill="#000" stroke="#fff" stroke-width="0.6" paint-order="stroke" text-anchor="middle">
        <text x="100" y="92" font-size="32" letter-spacing="3">I.A.S</text>
        <text x="100" y="124" font-size="14" letter-spacing="2">INTELIGÊNCIA</text>
        <text x="100" y="146" font-size="14" letter-spacing="2">AS A SERVICE</text>
      </g>
    </svg>
  </div>

  <div class="hero-main">
    <div class="hero-eyebrow">
      <span class="hf-mono kicker" data-live-date data-lang={lang}>
        <span class="d-day">{dateDay}</span> · <span class="d-mon">{dateMon.toUpperCase()}</span> · <span class="d-yr">{dateYr}</span> · {locationLabel}
      </span>
      <span class="rec ed-blink">● REC</span>
    </div>

    <h1 class="hero-title ed-bungee">
      <span class="t-fg">{firstName.toUpperCase()}</span><br />
      <span class="t-stroke ed-bungee-s">{lastFirstHalf.toUpperCase()}</span><span class="t-hot">{lastSecondHalf.toUpperCase()}</span><span class="ed-blink t-cyan">_</span>
    </h1>

    <p class="hero-intro ed-mono">
      {lang === 'en' ? (
        <>
          I create <span class="ed-mark-hot">products</span>, develop <span class="ed-mark-cyan">strategies</span>, do research and <span class="ed-mark-acid">analysis</span>, teach <span class="ed-mark-vio">classes</span>, think up and execute <span class="ed-mark-ylw">ideas</span> — all with a touch of <span class="ed-mark-orng">groove</span>. I like technology, culture, games, music and journalism. I also like potatoes and <span class="ed-mark-blue">studying</span>.
        </>
      ) : (
        <>
          Crio <span class="ed-mark-hot">produtos</span>, desenvolvo <span class="ed-mark-cyan">estratégias</span>, faço pesquisas e <span class="ed-mark-acid">análises</span>, dou <span class="ed-mark-vio">aulas</span>, penso e executo <span class="ed-mark-ylw">ideias</span> — tudo com um tiquinho de <span class="ed-mark-orng">molho</span>. Gosto de tecnologia, cultura, games, música e jornalismo. Também gosto de batata e de <span class="ed-mark-blue">estudar</span>.
        </>
      )}
    </p>

    <div class="hero-cta">
      <a class="ed-btn acid" href={blogHref}>{t.home.ctaBlog}</a>
      <a class="ed-btn ylw" href={cvPdfHref} download>↓ {t.home.ctaCV}</a>
    </div>
  </div>

  <div class="hero-tags">
    {heroTags.map((tag, i) => (
      <span class={`ed-tag t-${i % 3}`}>#{tag}</span>
    ))}
  </div>
</section>

<section class="brutal-index">
  <div class="bi-head">
    <div class="bi-kicker hf-mono">{'>>>'} {indexHeading}</div>
    <div class="bi-counter ed-tiny">{entriesLabel}</div>
  </div>
  <hr class="ed-rule-rainbow" />

  {indexEntries.map((s) => (
    <a class="bi-row" href={s.href} style={`--row-c:${s.color}`}>
      <span class="bi-num">[{s.n}]</span>
      <span class="bi-title ed-bungee">{s.t}</span>
      <span class="bi-sub">{s.sub}</span>
      <span class="bi-meta">{s.meta}</span>
      <span class="bi-arr">→</span>
    </a>
  ))}
</section>

{recentPosts.length > 0 && (
  <section class="from-blog">
    <div class="fb-head">
      <h2 class="ed-bungee fb-title">{fromBlogHeading}</h2>
      <a class="fb-all hf-mono" href={blogHref}>{allPostsLabel}</a>
    </div>
    <div class="fb-grid">
      {recentPosts.map((p) => (
        <a class="fb-card" href={postHref(p.id)}>
          <span class="fb-tag">#{tagDisplay[lang][p.data.tag] ?? p.data.tag}</span>
          <h3 class="ed-bungee fb-card-title">{p.data.title}</h3>
          <div class="fb-meta hf-mono">
            {formatDate(p.data.pubDate, lang).toUpperCase()} · {p.data.readingTime} min
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .hero {
    position: relative;
    padding: 30px 0 36px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: flex-start;
  }
  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }
  .hero-main, .hero-tags { position: relative; z-index: 1; }

  .ai-seal {
    position: absolute;
    top: 40px;
    right: 0;
    width: 200px;
    height: 200px;
    z-index: 2;
    transform: rotate(-8deg);
    filter: drop-shadow(4px 6px 0 rgba(0, 0, 0, 0.55));
    pointer-events: none;
    animation: ai-seal-wobble 3.4s ease-in-out infinite;
  }
  .ai-seal svg { width: 100%; height: 100%; display: block; }
  @keyframes ai-seal-wobble {
    0%, 100% { transform: rotate(-8deg); }
    50%      { transform: rotate(-4deg); }
  }
  @media (max-width: 960px) {
    .ai-seal { width: 150px; height: 150px; top: 24px; }
  }
  @media (max-width: 720px) {
    .ai-seal { width: 110px; height: 110px; top: 14px; right: 0; }
  }

  .hero-eyebrow {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 14px;
  }
  .hero-eyebrow .kicker {
    font-size: 11px;
    color: var(--acid);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .rec {
    color: var(--hot);
    font-size: 11px;
    font-family: var(--mono);
    letter-spacing: 0.1em;
  }

  .hero-title {
    font-size: clamp(56px, 12vw, 168px);
    margin: 0;
    line-height: 0.82;
    letter-spacing: -0.06em;
    text-transform: uppercase;
  }
  .t-fg { color: var(--fg); }
  .t-hot { color: var(--hot); }
  .t-cyan { color: var(--cyan); }
  .t-stroke {
    color: var(--bg);
    -webkit-text-stroke: 2.5px var(--fg);
  }

  .hero-intro {
    font-size: 16px;
    max-width: 760px;
    margin-top: 24px;
    line-height: 1.4;
  }

  .hero-cta {
    margin-top: 22px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .hero-tags {
    grid-column: 1 / -1;
    display: flex;
    gap: 6px;
    margin-top: 32px;
    flex-wrap: wrap;
  }
  .hero-tags .t-0 { background: var(--hot); color: #000; border-color: #000; }
  .hero-tags .t-1 { background: transparent; color: var(--fg); border-color: var(--fg); }
  .hero-tags .t-2 { background: var(--cyan); color: #000; border-color: #000; }

  .brutal-index { margin: 30px 0 0; }
  .bi-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 6px;
  }
  .bi-kicker {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--acid);
  }
  .bi-counter { color: var(--fg); font-size: 9px; }

  .bi-row {
    display: grid;
    grid-template-columns: 50px 1fr 220px 90px 28px;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1.5px solid var(--fg);
    gap: 14px;
    color: var(--fg);
    transition: padding-left 0.12s linear, background 0.05s linear;
  }
  .bi-row:hover {
    background: transparent;
    padding-left: 8px;
  }
  .bi-row:hover .bi-arr { color: var(--ylw); }
  .bi-row .bi-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--row-c);
  }
  .bi-row .bi-title {
    font-size: clamp(24px, 4vw, 42px);
    letter-spacing: -0.03em;
    color: var(--fg);
  }
  .bi-row:hover .bi-title { color: var(--row-c); }
  .bi-row .bi-sub {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg);
    opacity: 0.7;
  }
  .bi-row .bi-meta {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--row-c);
    text-align: right;
    text-transform: uppercase;
  }
  .bi-row .bi-arr {
    font-size: 22px;
    color: var(--row-c);
    text-align: right;
  }

  .from-blog { margin-top: 56px; }
  .fb-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .fb-title {
    font-size: 36px;
    margin: 0;
    letter-spacing: -0.03em;
  }
  .fb-all {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--vio);
  }
  .fb-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .fb-card {
    display: block;
    padding: 18px;
    border: 2px solid var(--fg);
    border-left: none;
    cursor: pointer;
  }
  .fb-card:first-child { border-left: 2px solid var(--fg); }
  .fb-card:hover { background: var(--bg-2); color: inherit; }
  .fb-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--vio);
    text-transform: uppercase;
  }
  .fb-card-title {
    font-size: 22px;
    margin: 8px 0 12px;
    letter-spacing: -0.02em;
    line-height: 1.05;
    text-transform: uppercase;
  }
  .fb-meta {
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    text-transform: uppercase;
  }

  @media (max-width: 960px) {
    .bi-row {
      grid-template-columns: 40px 1fr 60px 24px;
      gap: 10px;
    }
    .bi-row .bi-sub { display: none; }
    .fb-grid { grid-template-columns: 1fr; }
    .fb-card { border-left: 2px solid var(--fg); border-top: none; }
    .fb-card:first-child { border-top: 2px solid var(--fg); }
  }
  @media (max-width: 720px) {
    .hero-title { font-size: clamp(40px, 14vw, 80px); }
    .fb-title { font-size: 28px; }
  }
</style>

<script>
  const monthsByLang: Record<string, string[]> = {
    pt: ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'],
    en: ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'],
  };
  const update = () => {
    const now = new Date();
    document.querySelectorAll<HTMLElement>('[data-live-date]').forEach((el) => {
      const lang = el.dataset.lang === 'en' ? 'en' : 'pt';
      const day = el.querySelector<HTMLElement>('.d-day');
      const mon = el.querySelector<HTMLElement>('.d-mon');
      const yr = el.querySelector<HTMLElement>('.d-yr');
      if (day) day.textContent = String(now.getDate()).padStart(2, '0');
      if (mon) mon.textContent = monthsByLang[lang][now.getMonth()].toUpperCase();
      if (yr) yr.textContent = String(now.getFullYear());
    });
  };
  update();
</script>
