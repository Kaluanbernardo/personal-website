---
import { getCollection } from 'astro:content';
import { ui, type Lang, formatDate, formatLongDate, tagDisplay } from '../../i18n/ui';
import { link } from '../../lib/links';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.lang === lang);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allProjects = await getCollection('projects', ({ data }) => data.lang === lang);

const prefix = lang === 'en' ? '/en' : '';
const postHref = (slug: string) => link(`${prefix}/blog/${slug}`);
const blogHref = link(`${prefix}/blog`);
const cvPdfHref = link(lang === 'en' ? '/cv-en.pdf' : '/cv-pt.pdf');

const indexEntries = [
  {
    n: '01',
    t: lang === 'en' ? 'ABOUT' : 'SOBRE',
    sub: '> who_is_this.txt',
    meta: lang === 'en' ? '2 min' : '2 min',
    href: link(`${prefix}/sobre`),
    color: 'var(--cyan)',
  },
  {
    n: '02',
    t: lang === 'en' ? 'PROFESSIONAL CV' : 'CV PROFISSIONAL',
    sub: '> work_history.pdf',
    meta: 'PDF',
    href: link(`${prefix}/cv`),
    color: 'var(--ylw)',
  },
  {
    n: '03',
    t: lang === 'en' ? 'ACADEMIC CV' : 'CV ACADÊMICO',
    sub: '> lattes.cnpq.br',
    meta: 'CV',
    href: link(`${prefix}/academico`),
    color: 'var(--acid)',
  },
  {
    n: '04',
    t: lang === 'en' ? 'PROJECTS' : 'PROJETOS',
    sub: '> ./output/*',
    meta: lang === 'en'
      ? `${allProjects.length} ${allProjects.length === 1 ? 'item' : 'items'}`
      : `${allProjects.length} ${allProjects.length === 1 ? 'item' : 'itens'}`,
    href: link(`${prefix}/projetos`),
    color: 'var(--orng)',
  },
  {
    n: '05',
    t: 'BLOG',
    sub: '> cat *.md',
    meta: lang === 'en'
      ? `${allPosts.length} ${allPosts.length === 1 ? 'post' : 'posts'}`
      : `${allPosts.length} posts`,
    href: blogHref,
    color: 'var(--vio)',
  },
  {
    n: '06',
    t: lang === 'en' ? 'CONTACT' : 'CONTATO',
    sub: '> echo $EMAIL',
    meta: '@',
    href: link(`${prefix}/contato`),
    color: 'var(--hot)',
  },
];

const heroTags = lang === 'en'
  ? ['Product', 'Journalism', 'Content', 'Technology', 'Games', 'Culture', 'Strategy', 'AI', 'Anything_You_Want_Just_Dream']
  : ['Produto', 'Jornalismo', 'Conteúdo', 'Tecnologia', 'Games', 'Cultura', 'Estratégia', 'IA', 'Tudo_O_Que_Você_Quiser_Basta_Sonhar'];

const now = new Date();
const [dateDay, dateMon, dateYr] = formatLongDate(now, lang).split(' ');
const locationLabel = lang === 'en'
  ? 'SÃO PAULO, BRAZIL, SOUTH AMERICA, EARTH'
  : 'SÃO PAULO, BRASIL, AMÉRICA DO SUL, TERRA';
const indexHeading = lang === 'en' ? 'INDEX / RAW NAVIGATION' : 'ÍNDICE / NAVEGAÇÃO RAW';
const entriesLabel = lang === 'en' ? `0${indexEntries.length}_ENTRIES` : `0${indexEntries.length}_ENTRADAS`;

const fromBlogHeading = lang === 'en' ? 'FROM THE BLOG.' : 'DO BLOG.';
const allPostsLabel = lang === 'en' ? 'ALL POSTS →' : 'TODOS OS POSTS →';

const heroTitle = (t.brand || '').split(' ');
const firstName = heroTitle[0] || 'NOME';
const lastName = heroTitle.slice(1).join(' ') || 'SOBRENOME';
const lastFirstHalf = lastName.slice(0, Math.ceil(lastName.length / 2)) || 'SOBRE';
const lastSecondHalf = lastName.slice(Math.ceil(lastName.length / 2)) || 'NOME';
---

<section class="hero">
  <div class="hero-grid-bg" aria-hidden="true"></div>

  <div class="hero-main">
    <div class="hero-eyebrow">
      <span class="hf-mono kicker" data-live-date data-lang={lang}>
        <span class="d-day">{dateDay}</span> · <span class="d-mon">{dateMon.toUpperCase()}</span> · <span class="d-yr">{dateYr}</span> · {locationLabel}
      </span>
      <span class="rec ad-blink">● REC</span>
    </div>

    <h1 class="hero-title ad-bungee">
      <span class="t-fg">{firstName.toUpperCase()}</span><br />
      <span class="t-stroke ad-bungee-s">{lastFirstHalf.toUpperCase()}</span><span class="t-hot">{lastSecondHalf.toUpperCase()}</span><span class="ad-blink t-cyan">_</span>
    </h1>

    <p class="hero-intro ad-mono">
      {lang === 'en' ? (
        <>
          I create <span class="ad-mark-hot">products</span>, develop <span class="ad-mark-cyan">strategies</span>, do research and <span class="ad-mark-acid">analysis</span>, think up and execute <span class="ad-mark-ylw">ideas</span> — all with a touch of <span class="ad-mark-orng">groove</span> and a bit of carimbó. I like technology, culture, games music and journalism. I also like <span class="ad-mark-vio">potatoes</span> and <span class="ad-mark-blue">studying</span>.
        </>
      ) : (
        <>
          Crio <span class="ad-mark-hot">produtos</span>, desenvolvo <span class="ad-mark-cyan">estratégias</span>, faço pesquisas e <span class="ad-mark-acid">análises</span>, penso e executo <span class="ad-mark-ylw">ideias</span> — tudo com um tiquinho de <span class="ad-mark-orng">molho</span> e carimbó. Gosto de tecnologia, cultura, games música e jornalismo. Também gosto de <span class="ad-mark-vio">batata</span> e de <span class="ad-mark-blue">estudar</span>.
        </>
      )}
    </p>

    <div class="hero-cta">
      <a class="ad-btn acid" href={blogHref}>{t.home.ctaBlog}</a>
      <a class="ad-btn ylw" href={cvPdfHref} download>↓ {t.home.ctaCV}</a>
    </div>
  </div>

  <aside class="hero-aside">
    <div class="ad-sticker stamp">★ EST. 2026 ★</div>
    <div class="now-playing ad-box">
      <div class="np-kicker">{'> '}{lang === 'en' ? 'NOW PLAYING' : 'NOW PLAYING'}</div>
      <div class="np-track">TIM MAIA — IMUNIZAÇÃO RACIONAL</div>
      <div class="np-time">03:42 / 06:18</div>
      <div class="np-bar"><span></span></div>
    </div>
    <div class="visits ad-tiny">VISITS: 0001337</div>
  </aside>

  <div class="hero-tags">
    {heroTags.map((tag, i) => (
      <span class={`ad-tag t-${i % 3}`}>#{tag}</span>
    ))}
  </div>
</section>

<section class="brutal-index">
  <div class="bi-head">
    <div class="bi-kicker hf-mono">{'>>>'} {indexHeading}</div>
    <div class="bi-counter ad-tiny">{entriesLabel}</div>
  </div>
  <hr class="ad-rule-rainbow" />

  {indexEntries.map((s) => (
    <a class="bi-row" href={s.href} style={`--row-c:${s.color}`}>
      <span class="bi-num">[{s.n}]</span>
      <span class="bi-title ad-bungee">{s.t}</span>
      <span class="bi-sub">{s.sub}</span>
      <span class="bi-meta">{s.meta}</span>
      <span class="bi-arr">→</span>
    </a>
  ))}
</section>

{recentPosts.length > 0 && (
  <section class="from-blog">
    <div class="fb-head">
      <h2 class="ad-bungee fb-title">{fromBlogHeading}</h2>
      <a class="fb-all hf-mono" href={blogHref}>{allPostsLabel}</a>
    </div>
    <div class="fb-grid">
      {recentPosts.map((p) => (
        <a class="fb-card" href={postHref(p.id)}>
          <span class="fb-tag">#{tagDisplay[lang][p.data.tag] ?? p.data.tag}</span>
          <h3 class="ad-bungee fb-card-title">{p.data.title}</h3>
          <div class="fb-meta hf-mono">
            {formatDate(p.data.pubDate, lang).toUpperCase()} · {p.data.readingTime} min
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .hero {
    position: relative;
    padding: 30px 0 36px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: flex-start;
  }
  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }
  :global([data-theme='light']) .hero-grid-bg {
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.08) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0,0,0,0.08) 1px, transparent 1px);
  }
  .hero-main, .hero-aside, .hero-tags { position: relative; z-index: 1; }

  .hero-eyebrow {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 14px;
  }
  .hero-eyebrow .kicker {
    font-size: 11px;
    color: var(--acid);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .rec {
    color: var(--hot);
    font-size: 11px;
    font-family: var(--mono);
    letter-spacing: 0.1em;
  }

  .hero-title {
    font-size: clamp(56px, 12vw, 168px);
    margin: 0;
    line-height: 0.82;
    letter-spacing: -0.06em;
    text-transform: uppercase;
  }
  .t-fg { color: var(--fg); }
  .t-hot { color: var(--hot); }
  .t-cyan { color: var(--cyan); }
  .t-stroke {
    color: var(--bg);
    -webkit-text-stroke: 2.5px var(--fg);
  }

  .hero-intro {
    font-size: 16px;
    max-width: 760px;
    margin-top: 24px;
    line-height: 1.4;
  }

  .hero-cta {
    margin-top: 22px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .hero-aside {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-end;
    min-width: 260px;
  }
  .stamp {
    background: transparent;
    color: var(--ylw);
    border-color: var(--ylw);
    transform: rotate(6deg);
    font-size: 10px;
    letter-spacing: 0.12em;
    align-self: flex-end;
  }
  .now-playing {
    border: 2px solid var(--fg);
    padding: 8px 14px;
    background: var(--bg);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    width: 240px;
  }
  .np-kicker { color: var(--acid); margin-bottom: 4px; }
  .np-track { letter-spacing: 0.04em; }
  .np-time { opacity: 0.5; margin-top: 4px; }
  .np-bar {
    height: 4px;
    background: #222;
    margin-top: 6px;
    position: relative;
  }
  :global([data-theme='light']) .np-bar { background: #cfc9b6; }
  .np-bar > span {
    position: absolute;
    inset: 0 auto 0 0;
    width: 58%;
    background: var(--hot);
  }
  .visits {
    border: 1.5px solid var(--cyan);
    color: var(--cyan);
    padding: 6px 8px;
    font-family: var(--tiny);
    font-size: 9px;
  }

  .hero-tags {
    grid-column: 1 / -1;
    display: flex;
    gap: 6px;
    margin-top: 32px;
    flex-wrap: wrap;
  }
  .hero-tags .t-0 { background: var(--hot); color: #000; border-color: #000; }
  .hero-tags .t-1 { background: transparent; color: var(--fg); border-color: var(--fg); }
  .hero-tags .t-2 { background: var(--cyan); color: #000; border-color: #000; }

  .brutal-index { margin: 30px 0 0; }
  .bi-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 6px;
  }
  .bi-kicker {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--acid);
  }
  .bi-counter { color: var(--fg); font-size: 9px; }

  .bi-row {
    display: grid;
    grid-template-columns: 50px 1fr 220px 90px 28px;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1.5px solid var(--fg);
    gap: 14px;
    color: var(--fg);
    transition: padding-left 0.12s linear, background 0.05s linear;
  }
  .bi-row:hover {
    background: transparent;
    padding-left: 8px;
  }
  .bi-row:hover .bi-arr { color: var(--ylw); }
  .bi-row .bi-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--row-c);
  }
  .bi-row .bi-title {
    font-size: clamp(24px, 4vw, 42px);
    letter-spacing: -0.03em;
    color: var(--fg);
  }
  .bi-row:hover .bi-title { color: var(--row-c); }
  .bi-row .bi-sub {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg);
    opacity: 0.7;
  }
  .bi-row .bi-meta {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--row-c);
    text-align: right;
    text-transform: uppercase;
  }
  .bi-row .bi-arr {
    font-size: 22px;
    color: var(--row-c);
    text-align: right;
  }

  .from-blog { margin-top: 56px; }
  .fb-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .fb-title {
    font-size: 36px;
    margin: 0;
    letter-spacing: -0.03em;
  }
  .fb-all {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--vio);
  }
  .fb-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .fb-card {
    display: block;
    padding: 18px;
    border: 2px solid var(--fg);
    border-left: none;
    cursor: pointer;
  }
  .fb-card:first-child { border-left: 2px solid var(--fg); }
  .fb-card:hover { background: var(--bg-2); color: inherit; }
  .fb-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--vio);
    text-transform: uppercase;
  }
  .fb-card-title {
    font-size: 22px;
    margin: 8px 0 12px;
    letter-spacing: -0.02em;
    line-height: 1.05;
    text-transform: uppercase;
  }
  .fb-meta {
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    text-transform: uppercase;
  }

  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-aside { align-items: flex-start; flex-direction: row; flex-wrap: wrap; }
    .now-playing { width: auto; flex: 1 1 240px; }
    .bi-row {
      grid-template-columns: 40px 1fr 60px 24px;
      gap: 10px;
    }
    .bi-row .bi-sub { display: none; }
    .fb-grid { grid-template-columns: 1fr; }
    .fb-card { border-left: 2px solid var(--fg); border-top: none; }
    .fb-card:first-child { border-top: 2px solid var(--fg); }
  }
  @media (max-width: 720px) {
    .hero-title { font-size: clamp(48px, 16vw, 96px); }
    .fb-title { font-size: 28px; }
  }
</style>

<script>
  const monthsByLang: Record<string, string[]> = {
    pt: ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'],
    en: ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'],
  };
  const update = () => {
    const now = new Date();
    document.querySelectorAll<HTMLElement>('[data-live-date]').forEach((el) => {
      const lang = el.dataset.lang === 'en' ? 'en' : 'pt';
      const day = el.querySelector<HTMLElement>('.d-day');
      const mon = el.querySelector<HTMLElement>('.d-mon');
      const yr = el.querySelector<HTMLElement>('.d-yr');
      if (day) day.textContent = String(now.getDate()).padStart(2, '0');
      if (mon) mon.textContent = monthsByLang[lang][now.getMonth()].toUpperCase();
      if (yr) yr.textContent = String(now.getFullYear());
    });
  };
  update();
</script>
