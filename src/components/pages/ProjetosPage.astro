---
import { getCollection } from 'astro:content';
import { ui, type Lang } from '../../i18n/ui';
import ProjectCard from '../ProjectCard.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const projects = (await getCollection('projects', ({ data }) => data.lang === lang))
  .map((p) => p.data)
  .sort((a, b) => b.year - a.year);

// Map filter labels (localized) back to canonical kind
const kindByFilter: Record<string, string | null> = {};
t.projetos.filters.forEach((label, i) => {
  if (i === 0) {
    kindByFilter[label] = null;
  } else {
    const order: string[] = ['jornalismo', 'produto', 'academia', 'palestra', 'pessoal'];
    kindByFilter[label] = order[i - 1];
  }
});
---

<div class="eyebrow hf-mono">{t.projetos.eyebrow}</div>
<h1 class="hf-display headline display-lg">{t.projetos.title}<span class="ital">.</span></h1>
<p class="sub hf-mono">{t.projetos.sub}</p>

<div class="filters">
  {t.projetos.filters.map((label, i) => (
    <button type="button" class={`hf-tag filter-btn ${i === 0 ? 'accent active' : ''}`} data-kind={kindByFilter[label] ?? ''}>
      {label}
    </button>
  ))}
</div>

<div class="grid">
  {projects.map((p) => (
    <div class="cell" data-kind={p.kind}>
      <ProjectCard
        title={p.title}
        kind={p.kind}
        place={p.place}
        href={p.url}
        lang={lang}
      />
    </div>
  ))}
</div>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cells = document.querySelectorAll<HTMLElement>('.cell');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('accent', 'active'));
      btn.classList.add('accent', 'active');
      const kind = btn.dataset.kind ?? '';
      cells.forEach((cell) => {
        if (!kind || cell.dataset.kind === kind) {
          cell.style.display = '';
        } else {
          cell.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .headline {
    font-size: 72px;
    margin: 0 0 8px;
    line-height: 0.95;
  }
  .ital {
    font-style: italic;
  }
  .sub {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin: 0 0 28px;
  }
  .filters {
    display: flex;
    gap: 6px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }
  .filter-btn {
    cursor: pointer;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .headline {
      font-size: 48px;
    }
  }
  @media (max-width: 1080px) and (min-width: 721px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
