---
import { getCollection } from 'astro:content';
import { ui, type Lang, tagDisplay } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const projects = (await getCollection('projects', ({ data }) => data.lang === lang))
  .map((p) => p.data)
  .sort((a, b) => b.year - a.year);

const kindOrder: string[] = ['jornalismo', 'produto', 'academia', 'palestra', 'pessoal'];
const kindByFilter: Record<string, string | null> = {};
t.projetos.filters.forEach((label, i) => {
  kindByFilter[label] = i === 0 ? null : kindOrder[i - 1] ?? null;
});

const eyebrow = '04 / ./OUTPUT/*';
const kindColor: Record<string, string> = {
  jornalismo: 'var(--hot)',
  produto: 'var(--cyan)',
  academia: 'var(--acid)',
  palestra: 'var(--vio)',
  pessoal: 'var(--ylw)',
};
---

<header class="head">
  <div class="kicker">{eyebrow}</div>
  <h1 class="ed-bungee headline">
    {t.projetos.title.toUpperCase()}<span class="dot">.</span>
  </h1>
  <div class="sub">{t.projetos.sub}</div>
</header>

<div class="filters" role="group" aria-label="filters">
  {t.projetos.filters.map((label, i) => (
    <button type="button" class={`ed-tag filter-btn ${i === 0 ? 'is-active' : ''}`} data-kind={kindByFilter[label] ?? ''}>
      #{label}
    </button>
  ))}
</div>

<div class="grid">
  {projects.map((p, i) => {
    const c = kindColor[p.kind] ?? 'var(--fg)';
    const rotate = i % 2 === 0 ? 'rotate(0.4deg)' : 'rotate(-0.4deg)';
    return (
      <article class="cell" data-kind={p.kind} style={`--card-c:${c};--rot:${rotate}`}>
        <a class="card" href={p.url ?? '#'} target={p.url ? '_blank' : undefined} rel={p.url ? 'noreferrer noopener' : undefined}>
          <div class="thumb ed-imgframe">
            <div class="ph">thumb · 4×3</div>
          </div>
          <div class="card-body">
            <span class="card-tag">#{tagDisplay[lang][p.kind] ?? p.kind}</span>
            <h3 class="ed-bungee card-title">{p.title}</h3>
            <div class="card-place">{p.place} →</div>
          </div>
        </a>
      </article>
    );
  })}
</div>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cells = document.querySelectorAll<HTMLElement>('.cell');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const kind = btn.dataset.kind ?? '';
      cells.forEach((cell) => {
        cell.style.display = !kind || cell.dataset.kind === kind ? '' : 'none';
      });
    });
  });
</script>

<style>
  .head { padding-top: 6px; margin-bottom: 18px; }
  .kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--orng);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .headline {
    font-size: clamp(48px, 9vw, 96px);
    margin: 0 0 6px;
    line-height: 0.85;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }
  .headline .dot { color: var(--orng); }
  .sub {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: 18px;
  }

  .filters {
    display: flex;
    gap: 4px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .filter-btn { font-size: 11px; padding: 4px 10px; }
  .filter-btn.is-active {
    background: var(--orng);
    color: #000;
    border-color: #000;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .cell {
    transform: var(--rot, none);
  }
  .card {
    display: block;
    border: 2.5px solid var(--fg);
    background: transparent;
    cursor: pointer;
    color: inherit;
  }
  .card:hover { background: var(--bg-2); color: inherit; }
  .thumb {
    aspect-ratio: 4/3;
    border-bottom: 2.5px solid var(--fg);
    color: var(--card-c);
  }
  .card-body { padding: 12px 14px; }
  .card-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--card-c);
    color: #000;
    border: 1.5px solid #000;
    padding: 2px 6px;
    margin-bottom: 8px;
  }
  .card-title {
    font-size: 20px;
    margin: 4px 0;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }
  .card-place {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  @media (max-width: 1080px) and (min-width: 721px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; gap: 14px; }
  }
</style>
