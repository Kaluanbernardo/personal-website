---
import { ui, type Lang } from '../../i18n/ui';
import { link } from '../../lib/links';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const eyebrow = lang === 'en' ? '01 / WHO_IS_THIS.TXT' : '01 / WHO_IS_THIS.TXT';

const factsheet: [string, string, string][] = lang === 'en'
  ? [
      ['NASC', '19xx', ''],
      ['BASE', 'São Paulo', ''],
      ['DEGR', 'PhD candidate', ''],
      ['PRON', 'he/him', ''],
      ['STAT', 'online', 'acid'],
      ['MOOD', 'focused', 'ylw'],
    ]
  : [
      ['NASC', '19xx', ''],
      ['BASE', 'São Paulo', ''],
      ['TÍTL', 'doutorando', ''],
      ['PRON', 'ele/dele', ''],
      ['STAT', 'online', 'acid'],
      ['MOOD', 'focado', 'ylw'],
    ];

const currentlyHeading = lang === 'en' ? '> CURRENTLY' : '> ATUALMENTE';
const notDoingHeading = lang === 'en' ? "> DON'T DO" : '> NÃO FAÇO';

const currentlyItems = lang === 'en'
  ? [
      'thesis: ch. 3 (attention & platforms)',
      'product: discovery in ed-tech',
      'reading: 4 books simultaneously',
      'taking freelance (selective)',
    ]
  : [
      'tese: cap. 3 (atenção e plataformas)',
      'produto: discovery em ed-tech',
      'leituras: 4 livros simultâneos',
      'aceitando freelas (mas seletivo)',
    ];

const notDoingItems = lang === 'en'
  ? [
      'twitter threads about product',
      'motivational talks',
      'free $0.00 mentoring',
      'NFT, onlyfans, crypto',
    ]
  : [
      'thread no twitter sobre produto',
      'palestras motivacionais',
      'mentoria a R$ 0,00',
      'NFT, onlyfans, cripto',
    ];

const ctaCV = lang === 'en' ? 'See CV →' : 'Ver CV →';
const ctaEmail = lang === 'en' ? 'Send email' : 'Mandar e-mail';
const ctaRSS = 'RSS feed.xml';
const photoLabel = lang === 'en' ? 'portrait.png' : 'retrato.png';
---

<div class="sobre-grid">
  <article>
    <div class="kicker hf-mono">{eyebrow}</div>
    <h1 class="ad-bungee headline">
      <span class="t-cyan">{lang === 'en' ? 'ABOUT' : 'SOBRE'}</span><br />
      <span class="ad-bungee-s">{lang === 'en' ? 'ME' : 'MIM,'}</span>
      <span class="ad-blink t-hot">_</span>
    </h1>

    <div class="serif body">
      <p>{t.sobre.p1Lead}{t.sobre.p1}</p>
      {t.sobre.p2 && <p>{t.sobre.p2}</p>}
    </div>

    <div class="cta-row">
      <a class="ad-btn cyan" href={link(`${lang === 'en' ? '/en' : ''}/cv`)}>{ctaCV}</a>
      <a class="ad-btn hot" href={link(`${lang === 'en' ? '/en' : ''}/contato`)}>{ctaEmail}</a>
      <a class="ad-btn" href="#">{ctaRSS}</a>
    </div>

    <hr class="ad-rule-dashed sep" />

    <div class="boxes">
      <div class="box box-acid">
        <div class="kicker box-kicker">{currentlyHeading}</div>
        <ul>
          {currentlyItems.map((i) => <li>{i}</li>)}
        </ul>
      </div>
      <div class="box box-ylw">
        <div class="kicker box-kicker">{notDoingHeading}</div>
        <ul>
          {notDoingItems.map((i) => <li>{i}</li>)}
        </ul>
      </div>
    </div>
  </article>

  <aside class="sidebar">
    <div class="ad-imgframe photo">
      <img src={link('/img/portrait.png')} alt="" onerror="this.remove()" />
      <div class="ph">{photoLabel}</div>
    </div>
    <div class="photo-credit">FOTO: ALGUM AMIGO · 2025</div>

    <div class="factsheet">
      <div class="kicker fs-kicker">FACTSHEET</div>
      <div class="fs-list">
        {factsheet.map(([k, v, c]) => (
          <div class="fs-row">
            <span class="fs-key">{k}</span>
            <span class={`fs-val ${c ? 'c-' + c : ''}`}>{v}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="barcode">
      <div class="bars" aria-hidden="true">
        {Array.from({ length: 60 }).map((_, i) => {
          const isOne = i % 2 === 0 || i % 5 === 0 || i % 7 === 0;
          return <span class={isOne ? 'b-1' : 'b-0'}></span>;
        })}
      </div>
      <span class="barcode-label">NS-2026-04-ABT</span>
    </div>

    <div class="kicker socials-kicker">{t.sobre.socialsHeading.toUpperCase()}</div>
    <div class="socials">
      {t.sobre.socials.map((s) => (
        <a class="social-row" href="#">
          <span class="s-name">{s}</span>
          <span class="s-arr">↗</span>
        </a>
      ))}
    </div>
  </aside>
</div>

<style>
  .sobre-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 32px;
    padding-top: 14px;
  }

  .kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--cyan);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .headline {
    font-size: clamp(48px, 9vw, 96px);
    margin: 0 0 24px;
    line-height: 0.85;
    text-transform: uppercase;
    letter-spacing: -0.05em;
  }
  .headline .t-cyan {
    background: var(--cyan);
    color: #000;
    padding: 0 8px;
  }
  .headline .t-hot { color: var(--hot); }

  .serif {
    font-family: var(--mono);
    font-size: 16px;
    line-height: 1.5;
    color: var(--fg);
    max-width: 640px;
    margin-bottom: 24px;
  }
  .serif p { margin: 0 0 14px; }

  .cta-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .sep { margin: 32px 0; }

  .boxes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .box {
    border: 2px solid;
    padding: 12px 14px;
  }
  .box ul {
    margin: 0;
    padding-left: 16px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.7;
  }
  .box-acid { border-color: var(--acid); }
  .box-acid .box-kicker { color: var(--acid); }
  .box-ylw { border-color: var(--ylw); }
  .box-ylw .box-kicker { color: var(--ylw); }
  .box-kicker {
    font-size: 10px;
    letter-spacing: 0.15em;
    margin-bottom: 6px;
  }

  .sidebar { display: flex; flex-direction: column; gap: 16px; }
  .photo { aspect-ratio: 4/5; color: var(--fg-2); }
  .photo-credit {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    color: var(--fg-3);
    text-align: right;
    text-transform: uppercase;
  }

  .factsheet {
    border: 2px solid var(--hot);
    padding: 12px 14px;
    color: var(--fg);
  }
  .fs-kicker { color: var(--hot); margin-bottom: 6px; font-size: 10px; }
  .fs-list { font-family: var(--mono); font-size: 11px; line-height: 1.7; }
  .fs-row { display: flex; gap: 4px; }
  .fs-key { width: 50px; }
  .fs-val.c-acid { color: var(--acid); }
  .fs-val.c-ylw { color: var(--ylw); }

  .barcode {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--fg);
  }
  .barcode .bars { display: flex; height: 28px; gap: 1px; }
  .barcode .bars > span { display: block; background: currentColor; }
  .barcode .b-1 { width: 2px; opacity: 1; }
  .barcode .b-0 { width: 1px; opacity: 0.45; }
  .barcode-label { opacity: 0.7; }

  .socials-kicker { color: var(--cyan); margin-top: 6px; }
  .socials { display: flex; flex-direction: column; gap: 0; }
  .social-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1.5px dashed var(--fg);
    font-family: var(--mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .social-row .s-arr { color: var(--cyan); }

  @media (max-width: 900px) {
    .sobre-grid { grid-template-columns: 1fr; }
    .boxes { grid-template-columns: 1fr; }
  }
</style>
