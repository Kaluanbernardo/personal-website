---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StatusBar from '../components/StatusBar.astro';
import type { Lang } from '../i18n/ui';

type Active = 'home' | 'sobre' | 'cv' | 'academico' | 'blog' | 'projetos' | 'contato';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  active?: Active;
  navVariant?: 'full' | 'back';
  backLabel?: string;
  backHref?: string;
}
const {
  title,
  description,
  lang,
  active = 'home',
  navVariant = 'full',
  backLabel,
  backHref,
} = Astro.props;
const pathname = Astro.url.pathname;

const themeMap: Record<Active, string> = {
  home: 'theme-home',
  sobre: 'theme-sobre',
  cv: 'theme-cv',
  academico: 'theme-academ',
  blog: 'theme-blog',
  projetos: 'theme-projetos',
  contato: 'theme-contato',
};
---

<Base title={title} description={description} lang={lang}>
  <div class={`page ${themeMap[active]}`}>
    <Nav
      lang={lang}
      active={active}
      variant={navVariant}
      backLabel={backLabel}
      backHref={backHref}
      pathname={pathname}
    />
    <main class="page-inner">
      <slot />
    </main>
    <Footer lang={lang} />
    <StatusBar />
  </div>
</Base>
